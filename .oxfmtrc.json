{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "none",
  "printWidth": 80,
  "singleQuote": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "build/",
    "dist/",
    "frontend/src/components/_dsfr/",
    "frontend/jest.polyfills.js",
    "node_modules/",
    "public/",
    "tools/"
  ]
}
