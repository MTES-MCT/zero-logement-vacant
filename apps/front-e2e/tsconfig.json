{
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "target": "esnext",
    "lib": ["es5", "dom"],
    "sourceMap": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["@testing-library/cypress", "cypress", "cypress-axe", "node"]
  },
  "include": ["cypress/**/*.ts"],
  "references": [
    {
      "path": "../../packages/models"
    }
  ]
}
