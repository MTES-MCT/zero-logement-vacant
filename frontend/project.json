{
  "name": "@zerologementvacant/front",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "frontend/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project test --web",
  "targets": {
    "prebuild": {
      "command": "react-dsfr update-icons",
      "options": {
        "cwd": "frontend"
      }
    },
    "postbuild": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "frontend",
        "commands": [
          "tsx src/scripts/generate-building-images.ts",
          "copyfiles -V -u 1 'public/map/*.png' dist"
        ],
        "parallel": false
      }
    },

    "predev": {
      "command": "react-dsfr update-icons",
      "options": {
        "cwd": "frontend"
      }
    }
  }
}
