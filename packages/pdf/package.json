{
  "name": "@zerologementvacant/pdf",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/lib/browser.d.ts",
      "import": "./dist/lib/browser.js"
    },
    "./node": {
      "types": "./dist/lib/node.d.ts",
      "import": "./dist/lib/node.js"
    },
    "./worker": {
      "import": "./dist/lib/generators/campaign.worker.js",
      "default": "./dist/lib/generators/campaign.worker.js"
    }
  },
  "dependencies": {
    "@react-pdf/renderer": "4.3.2",
    "@zerologementvacant/models": "workspace:*",
    "react": "18.3.1",
    "react-pdf-html": "2.1.5",
    "ts-pattern": "5.8.0"
  },
  "devDependencies": {
    "@faker-js/faker": "8.4.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "pdf-to-png-converter": "3.11.0",
    "react-dom": "18.3.1",
    "vite-plugin-dts": "4.5.4"
  },
  "peerDependencies": {
    "react": "18.3.1"
  }
}
