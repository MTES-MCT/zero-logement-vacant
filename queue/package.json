{
  "name": "@zerologementvacant/queue",
  "version": "0.0.1",
  "description": "Zéro Logement Vacant queue",
  "type": "module",
  "bin": "dist/app/bin/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/app/index.d.ts",
      "default": "./dist/app/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.app.json",
    "dev": "tsx src/bin/index.ts",
    "prestart": "htpasswd -c -B -b src/.htpasswd $QUEUE_DASHBOARD_USERNAME $QUEUE_DASHBOARD_PASSWORD",
    "start": "tsx src/bin/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.864.0",
    "@aws-sdk/lib-storage": "3.864.0",
    "@bull-board/api": "6.13.0",
    "@bull-board/express": "6.13.0",
    "@bull-board/ui": "6.13.0",
    "@sentry/integrations": "7.120.4",
    "@sentry/node": "7.120.4",
    "@zerologementvacant/api-sdk": "workspace:*",
    "@zerologementvacant/draft": "workspace:*",
    "@zerologementvacant/healthcheck": "workspace:*",
    "@zerologementvacant/models": "workspace:*",
    "@zerologementvacant/utils": "workspace:*",
    "archiver": "7.0.1",
    "async": "3.2.6",
    "bullmq": "5.56.10",
    "convict": "6.2.5",
    "dotenv": "16.6.1",
    "express": "4.22.0",
    "helmet": "8.1.0",
    "htpasswd": "2.4.6",
    "http-auth": "4.2.1",
    "ioredis": "5.7.0",
    "parse-redis-url-simple": "1.0.2"
  },
  "devDependencies": {
    "@swc/core": "1.13.3",
    "@swc/jest": "0.2.39",
    "@tsconfig/node24": "24.0.4",
    "@types/archiver": "6.0.3",
    "@types/async": "3.2.25",
    "@types/convict": "6.1.6",
    "@types/express": "4.17.23",
    "@types/http-auth": "4.1.4",
    "@types/jest": "29.5.14",
    "@types/node": "24.2.1",
    "jest": "29.7.0",
    "jest-extended": "4.0.2",
    "tsx": "4.20.3"
  }
}
